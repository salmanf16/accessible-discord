msgid "Accessible Discord"
msgstr "Accessible Discord"

msgid "Announce headset deafen/undeafen status changes"
msgstr "نطق تعطيل وتفعيل سمع الأعضاء"

msgid "Announce incoming text messages in the active channel"
msgstr "نطق الرسائل النصية الواردة بالقناة النشطة"

msgid "Announce microphone mute/unmute status changes"
msgstr "نطق كتم وإلغاء كتم ميكروفون الأعضاء"

msgid "Announce when members join a voice channel"
msgstr "نطق انضمام الأعضاء للقناة الصوتية"

msgid "Announce when members join or leave your stream"
msgstr "نطق انضمام ومغادرة الأعضاء لبثك"

msgid "Announce when members leave a voice channel"
msgstr "نطق مغادرة الأعضاء للقناة الصوتية"

msgid "Announce when members start or stop streaming"
msgstr "نطق بدء وإيقاف بث الأعضاء"

msgid "BetterDiscord companion plugin copied automatically. Please enable it in Discord settings."
msgstr "تم تثبيت ملحق ديسكورد المساعد تلقائياً بنجاح. يرجى تفعيله من إعدادات ديسكورد."

msgid "BetterDiscord installer downloaded and opened successfully. Please complete the installation in the opened window."
msgstr "تم تحميل مثبت BetterDiscord بنجاح وفتحه. يرجى إكمال التثبيت من النافذة المفتوحة."

msgid "Calculating..."
msgstr "جاري الحساب..."

msgid "Connecting to server..."
msgstr "جاري الاتصال بالخادم..."

msgid "Download failed, retry"
msgstr "فشل التحميل، اضغط لإعادة المحاولة"

msgid "Downloaded {downloaded} KB"
msgstr "تم تحميل {downloaded} ك.ب"

msgid "Downloaded {downloaded} KB of {total} KB ({percent}%)\nTime remaining: {remaining}"
msgstr "تم تحميل {downloaded} ك.ب من أصل {total} ك.ب ({percent}%)\nالوقت المتبقي: {remaining}"

msgid "Downloading BetterDiscord"
msgstr "تحميل BetterDiscord"

msgid "Downloading BetterDiscord installer, please wait..."
msgstr "جاري تحميل مثبت BetterDiscord المساعد، يرجى الانتظار..."

msgid "Downloading..."
msgstr "جاري التحميل..."

msgid "Failed to download BetterDiscord: {error}"
msgstr "فشل تحميل BetterDiscord: {error}"

msgid "Install BetterDiscord"
msgstr "تثبيت BetterDiscord"

msgid "New message from {user}: {content}"
msgstr "رسالة جديدة من {user}: {content}"

msgid "deafened"
msgstr "عطل السمع"

msgid "muted"
msgstr "كتم الصوت"

msgid "undeafened"
msgstr "فعل السمع"

msgid "unmuted"
msgstr "ألغى كتم الصوت"

msgid "{minutes} min and {seconds} sec"
msgstr "{minutes} دقيقة و {seconds} ثانية"

msgid "{seconds} sec"
msgstr "{seconds} ثانية"

msgid "{user} joined"
msgstr "{user} انضم للقناة"

msgid "{user} joined voice channel {channel}"
msgstr "{user} انضم إلى القناة الصوتية {channel}"

msgid "{user} joined your stream"
msgstr "{user} انضم إلى بثك"

msgid "{user} left"
msgstr "{user} غادر القناة"

msgid "{user} left voice channel {channel}"
msgstr "{user} غادر القناة الصوتية {channel}"

msgid "{user} left your stream"
msgstr "{user} غادر بثك"

msgid "{user} started streaming"
msgstr "{user} بدأ بثاً"

msgid "{user} started streaming {target}"
msgstr "{user} بدأ بثاً لـ {target}"

msgid "{user} stopped streaming"
msgstr "{user} أوقف البث"

msgid "{user} {state}"
msgstr "{user} {state}"

